{
  "manifest_version": 3,
  "name": "VaakSetu — Agent Translator",
  "short_name": "VaakSetu",
  "version": "0.1.0",
  "description": "Real-time voice translator overlay for call-center agents. Tap customer / agent buttons on any call to translate speech both ways.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "VaakSetu Translator",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "tabCapture",
    "offscreen",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://vaak-setu.vercel.app/*",
    "https://api.sarvam.ai/*",
    "wss://api.sarvam.ai/*",
    "https://*.supabase.co/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js":      ["widget/widget.js"],
      "css":     ["widget/widget.css"],
      "run_at":  "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["widget/*", "icons/*"],
      "matches":   ["<all_urls>"]
    }
  ],
  "externally_connectable": {
    "matches": ["https://vaak-setu.vercel.app/*"]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
