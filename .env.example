# ─── Existing AI provider keys ────────────────────────────────────────────────
# Copy to .env and fill in. VITE_* vars are exposed to the browser bundle.
VITE_SARVAM_API_KEY=
VITE_GROQ_API_KEY=
VITE_ELEVENLABS_API_KEY=
VITE_OPENAI_API_KEY=

# ─── Supabase (auth + usage tracking) ─────────────────────────────────────────
# Leave BLANK in .env to run the webapp without login (dev mode).
# For local dev after `supabase start`, use the local values below.
# For prod on Vercel, set these to your hosted Supabase project.

# Local values after `supabase start` (printed in the terminal output):
#   VITE_SUPABASE_URL=http://localhost:54321
#   VITE_SUPABASE_ANON_KEY=<the "anon key" printed by `supabase start`>

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only (Vercel functions) — NEVER prefix with VITE_ or it leaks to the
# browser bundle. Needed by api/_auth.js to validate JWTs and write usage rows.
# Local dev: the service_role key printed by `supabase start`.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
